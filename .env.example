# =============================
# Core model/auth settings
# =============================
VITE_VERTEX_API_KEY=
VITE_GOOGLE_GENAI_USE_VERTEXAI=true
VITE_GOOGLE_CLOUD_PROJECT=
VITE_GOOGLE_CLOUD_LOCATION=us-central1
VITE_GOOGLE_CLOUD_LOCATION_LIVE=us-central1
VITE_GOOGLE_CLOUD_LOCATION_TOOLS=global
VITE_GOOGLE_GENAI_USE_VERTEXAI=true

# Voice manager model (Gemini Live)
VITE_GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview-native-audio-09-2025

# Canvas tool agent model
VITE_GEMINI_TOOL_MODEL=gemini-3.1-flash-lite-preview

# Visual model used for REST image analysis fallback
VITE_GEMINI_VISION_MODEL=gemini-2.5-flash

# Canvas tool-agent thinking budget (0 disables thinking)
VITE_GEMINI_TOOL_THINKING_BUDGET=200

VITE_GEMINI_MODEL_VIDEO="veo-3.1-generate-preview"
VITE_GEMINI_VOICE_MODEL_AUDIO=gemini-2.5-flash-preview-tts


# =============================
# API runtime settings

DRY_RUN=1 # can set it to 0 for using the api and 1 for not using api for testing purpose only
CLEAN_AFTER_ARCHIVE=1
NOTIFICATION_INTERVAL_SECONDS=10
REAL_MEMORY_POLL_SECONDS=1

API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=0
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
# Optional regex for LAN/dev origins (e.g. http://192.168.x.x:8080)
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127[.]0[.]0[.]1|192[.]168[.]\d{1,3}[.]\d{1,3}|10[.]\d{1,3}[.]\d{1,3}[.]\d{1,3}|172[.](1[6-9]|2\d|3[0-1])[.]\d{1,3}[.]\d{1,3})(:\d+)?$

# Langfuse Observability + Prompt Management (optional)
LANGFUSE_TRACING_ENABLED=1
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=development

# Optional: use Langfuse-hosted manager prompt instead of local prompt.md
LANGFUSE_USE_MANAGED_PROMPT=0
LANGFUSE_MANAGER_PROMPT_NAME=et-agent-manager
LANGFUSE_MANAGER_PROMPT_LABEL=production
LANGFUSE_MANAGER_PROMPT_CACHE_TTL_SECONDS=30

# Frontend runtime
VITE_API_BASE_URL=http://127.0.0.1:8000
